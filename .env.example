# CryptoFlow — Environment Variables
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/crypto_data

# Redis
REDIS_URL=redis://localhost:6379

# RapidAPI (set from RapidAPI provider dashboard → Security tab)
RAPIDAPI_PROXY_SECRET=

# Symbols to track (comma-separated Binance Futures pairs)
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# Exchanges to connect (comma-separated: binance,bybit,okx)
ENABLED_EXCHANGES=binance,bybit,okx

# API Gateway
PORT=8000
HOST=0.0.0.0

# Ingestion tuning
BATCH_FLUSH_INTERVAL=0.5
BATCH_MAX_SIZE=200
DATA_RETENTION_DAYS=30

# Analytics
LARGE_TRADE_THRESHOLD_USD=100000
CRUNCH_INTERVAL=1.0
